{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raven-manor.example/schemas/level.schema.json",
  "title": "Raven Manor level catalog",
  "description": "Data contract for the level definitions loaded by the vertical slice.",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "schemaVersion",
      "id",
      "title",
      "moves",
      "requiredStars",
      "objectives"
    ],
    "properties": {
      "schemaVersion": {
        "const": 1
      },
      "id": {
        "type": "integer",
        "minimum": 1
      },
      "title": {
        "type": "string",
        "minLength": 1
      },
      "moves": {
        "type": "integer",
        "minimum": 1
      },
      "requiredStars": {
        "type": "integer",
        "minimum": 0
      },
      "objectives": {
        "type": "array",
        "minItems": 1,
        "items": {
          "oneOf": [
            {
              "$ref": "#/$defs/collectObjective"
            }
          ]
        }
      }
    }
  },
  "$defs": {
    "collectObjective": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "tileType", "target"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "const": "collect"
        },
        "tileType": {
          "type": "integer",
          "minimum": 0
        },
        "target": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  }
}
