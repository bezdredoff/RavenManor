{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raven-manor.example/schemas/level.schema.json",
  "title": "Raven Manor level catalog",
  "description": "Data contract for scalable match-3 level definitions.",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "schemaVersion",
      "id",
      "title",
      "difficulty",
      "moves",
      "starThresholds",
      "objectives"
    ],
    "properties": {
      "schemaVersion": { "const": 2 },
      "id": { "type": "integer", "minimum": 1 },
      "title": { "type": "string", "minLength": 1 },
      "difficulty": {
        "type": "string",
        "enum": ["easy", "normal", "hard", "finale"]
      },
      "moves": { "type": "integer", "minimum": 1 },
      "starThresholds": {
        "$ref": "#/definitions/starThresholds"
      },
      "objectives": {
        "type": "array",
        "minItems": 1,
        "items": {
          "oneOf": [
            { "$ref": "#/definitions/collectObjective" }
          ]
        }
      }
    }
  },
  "definitions": {
    "starThresholds": {
      "type": "object",
      "additionalProperties": false,
      "required": ["twoStarsMovesLeft", "threeStarsMovesLeft"],
      "properties": {
        "twoStarsMovesLeft": { "type": "integer", "minimum": 0 },
        "threeStarsMovesLeft": { "type": "integer", "minimum": 1 }
      }
    },
    "collectObjective": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "tileType", "target"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "type": { "const": "collect" },
        "tileType": {
          "type": "integer",
          "minimum": 0,
          "maximum": 5
        },
        "target": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
