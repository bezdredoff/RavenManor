{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raven-manor.example/schemas/level-group.schema.json",
  "title": "Raven Manor level progression groups",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "schemaVersion",
      "id",
      "title",
      "description",
      "levelIds",
      "unlock"
    ],
    "properties": {
      "schemaVersion": { "const": 1 },
      "id": { "type": "string", "minLength": 1 },
      "title": { "type": "string", "minLength": 1 },
      "description": { "type": "string", "minLength": 1 },
      "levelIds": {
        "type": "array",
        "minItems": 1,
        "uniqueItems": true,
        "items": { "type": "integer", "minimum": 1 }
      },
      "unlock": {
        "oneOf": [
          { "$ref": "#/definitions/always" },
          { "$ref": "#/definitions/completeInGroup" }
        ]
      }
    }
  },
  "definitions": {
    "always": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": { "type": { "const": "always" } }
    },
    "completeInGroup": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "groupId", "count"],
      "properties": {
        "type": { "const": "complete-in-group" },
        "groupId": { "type": "string", "minLength": 1 },
        "count": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
